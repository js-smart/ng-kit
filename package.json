{
  "name": "ng-kit",
  "version": "22.2.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve ng-kit-demo --port=4300",
    "start:docs": "ng serve ng-kit-docs  --port=4301",
    "build": "ng build ng-kit --configuration=production",
    "build:demo": "ng build ng-kit-demo --configuration=production",
    "build:docs": "ng build ng-kit-docs --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test ng-kit --watch=false",
    "test:store": "ng test --include='**/store/*.spec.ts'",
    "bundle:report": "ng build --configuration production --source-map=true && source-map-explorer dist/pres/**/*.js",
    "e2e": "CI=true URL=http://localhost:4300 npx playwright test ng-kit-demo",
    "lint": "ng lint ng-kit",
    "serve:ssr:ng-kit-docs": "node dist/ng-kit-docs/server/server.mjs"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "dist/ng-kit"
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^22.0.4",
    "@angular/cdk": "22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "@angular/platform-server": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@angular/ssr": "22.0.4",
    "@ng-doc/app": "21.0.5",
    "@ng-doc/builder": "21.0.5",
    "@ng-doc/core": "21.0.5",
    "@ng-doc/ui-kit": "21.0.5",
    "@tanstack/query-core": "^5.101.1",
    "@tinkoff/ng-polymorpheus": "4.3.0",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "flex-controls": "^2.0.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.4",
    "@angular-devkit/schematics": "^22.0.4",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "^22.0.4",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@sonar/scan": "^4.3.8",
    "@stackblitz/sdk": "^1.11.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/browser-playwright": "^4.1.9",
    "angular-eslint": "22.0.0",
    "baseline-browser-mapping": "^2.10.38",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "istanbul-lib-instrument": "^6.0.3",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "^4.1.9",
    "zone.js": "~0.16.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 ChromeAndroid versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari major versions",
    "last 2 iOS major versions"
  ]
}
